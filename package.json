{
  "name": "zoje-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "deploy:start": "node dist/scripts/migrate.js && node dist/scripts/seedAdmin.js && node dist/src/server.js",
    "deploy:seed": "node dist/scripts/migrate.js && node dist/scripts/seed.js && node dist/scripts/seedAdmin.js",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed:admin": "tsx scripts/seedAdmin.ts",
    "db:reset": "pnpm db:migrate && pnpm db:seed && pnpm db:seed:admin"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "multer": "^2.1.1",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
